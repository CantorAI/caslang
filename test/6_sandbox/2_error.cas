{"op":"caslang","version":"0.3"}
{"op":"sandbox.exec","cmd":"non_existent_command_xyz","as":"output"}
{"op":"str.print","msg":"Output: ${output}"}
{"op":"str.contains","s":"${output}","sub":"recog","as":"found_error1"}
{"op":"str.contains","s":"${output}","sub":"found","as":"found_error2"}
{"op":"flow.if","cond":"'${found_error1}' == 'True' or '${found_error2}' == 'True'"}
{"op":"str.print","msg":"Error Handled OK"}
{"op":"flow.else"}
{"op":"str.print","msg":"Error Handling Failed"}
{"op":"flow.endif"}
