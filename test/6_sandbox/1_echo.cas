{"op":"sandbox.exec","cmd":"echo hello_world","as":"output"}
{"op":"str.contains","s":"${output}","sub":"hello_world","as":"result"}
{"op":"flow.if","cond":"'${result}' == 'True'"}
{"op":"str.print","msg":"Echo Test OK"}
{"op":"flow.else"}
{"op":"str.print","msg":"Echo Test Failed: ${output}"}
{"op":"flow.endif"}
