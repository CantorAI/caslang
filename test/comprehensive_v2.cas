{"op":"caslang","version":"0.3"}
{"op":"flow.set","name":"results","value":"{}"}
{"op":"flow.set","name":"test_name","value":"CasLang Spec v2 Comprehensive Suite"}

{"op":"flow.set","name":"expr_a","value":5}
{"op":"flow.set","name":"expr_b","value":3}
{"op":"flow.set","name":"expr_add_res","value":"=${expr_a} + ${expr_b}"}
{"op":"flow.set","name":"expr_mul_res","value":"=${expr_a} * ${expr_b}"}

{"op":"flow.if","cond":"${expr_add_res} == 8"}
    {"op":"dict.set","dict":"${results}","key":"'expr_add'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'expr_add'","value":false}
{"op":"flow.endif"}

{"op":"flow.if","cond":"${expr_mul_res} == 15"}
    {"op":"dict.set","dict":"${results}","key":"'expr_mul'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'expr_mul'","value":false}
{"op":"flow.endif"}

{"op":"flow.set","name":"str_s","value":"Hello World World"}
{"op":"str.count","s":"${str_s}","sub":"World","as":"str_cnt"}

{"op":"flow.if","cond":"${str_cnt} == 2"}
    {"op":"dict.set","dict":"${results}","key":"'str_count'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'str_count'","value":false}
{"op":"flow.endif"}

{"op":"flow.set","name":"list_my_list","value":"[]"}
{"op":"list.append","list":"${list_my_list}","value":10}
{"op":"list.append","list":"${list_my_list}","value":20}
{"op":"list.len","list":"${list_my_list}","as":"list_l_len"}

{"op":"flow.if","cond":"${list_l_len} == 2"}
    {"op":"dict.set","dict":"${results}","key":"'list_len'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'list_len'","value":false}
{"op":"flow.endif"}

{"op":"list.range","from":0,"to":5,"step":1,"as":"list_rng"}
{"op":"list.len","list":"${list_rng}","as":"list_rng_len"}
{"op":"flow.if","cond":"${list_rng_len} == 5"}
    {"op":"dict.set","dict":"${results}","key":"'list_range'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'list_range'","value":false}
{"op":"flow.endif"}

{"op":"flow.set","name":"dict_d","value":"{}"}
{"op":"dict.set","dict":"${dict_d}","key":"'k1'","value":"v1"}
{"op":"dict.has","dict":"${dict_d}","key":"'k1'","as":"dict_has_k1"}
{"op":"dict.remove","dict":"${dict_d}","key":"'k1'"}
{"op":"dict.has","dict":"${dict_d}","key":"'k1'","as":"dict_has_k1_after"}

{"op":"flow.if","cond":"'${dict_has_k1}' == 'True'"}
    {"op":"dict.set","dict":"${results}","key":"'dict_has'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'dict_has'","value":false}
{"op":"flow.endif"}

{"op":"flow.if","cond":"${dict_has_k1_after} == false"}
    {"op":"dict.set","dict":"${results}","key":"'dict_remove'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'dict_remove'","value":false}
{"op":"flow.endif"}

{"op":"flow.set","name":"copy_original","value":"[]"}
{"op":"list.append","list":"${copy_original}","value":"A"}

{"op":"flow.set","name":"copy_clone","value":"${copy_original}"}
{"op":"list.append","list":"${copy_clone}","value":"B"}

{"op":"list.len","list":"${copy_original}","as":"copy_len_orig"}
{"op":"list.len","list":"${copy_clone}","as":"copy_len_clone"}

{"op":"flow.if","cond":"${copy_len_orig} == 1"}
    {"op":"dict.set","dict":"${results}","key":"'deep_copy_orig'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'deep_copy_orig'","value":false}
{"op":"flow.endif"}

{"op":"flow.if","cond":"${copy_len_clone} == 2"}
    {"op":"dict.set","dict":"${results}","key":"'deep_copy_clone'","value":true}
{"op":"flow.else"}
    {"op":"dict.set","dict":"${results}","key":"'deep_copy_clone'","value":false}
{"op":"flow.endif"}

{"op":"flow.return","value":"${results}"}
