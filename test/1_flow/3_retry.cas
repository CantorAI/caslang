{"op":"caslang","version":"0.3"}
{"op":"flow.set","name":"i","value":0}
{"op":"flow.retry_start","times":4,"backoff_ms":0}
    {"op":"flow.set","name":"i","value":"=${i} + 1"}
    {"op":"flow.if","cond":"${i} < 3"}
       {"op":"time.sleep","ms":1}
       {"op":"fs.read_file","path":"missing_force_error"}
    {"op":"flow.endif"}
{"op":"flow.retry_end"}
{"op":"flow.return","value":"${i}"}
