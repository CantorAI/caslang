{"op":"caslang","version":"0.3"}
{"op":"time.now","as":"start_time"}
{"op":"list.range","from":0,"to":50,"step":1,"as":"list_data"}
{"op":"flow.set","name":"total","value":0}
{"op":"flow.loop_start","var":"i","in":"${list_data}"}
    {"op":"flow.set","name":"v2","value":"=${i} * 2"}
    {"op":"flow.set","name":"total","value":"=${total} + ${v2}"}
    {"op":"str.upper","s":"item_${i}","as":"s_upper"}
{"op":"flow.loop_end"}

{"op":"time.now","as":"end_time"}
{"op":"flow.set","name":"duration","value":"=${end_time} - ${start_time}"}
{"op":"flow.return","value":"Duration: ${duration} ms, Total: ${total}"}
