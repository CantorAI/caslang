{"op":"caslang","version":"0.3"}
{"op":"sandbox.exec","cmd":"echo sandbox_test_ok","as":"out"}
{"op":"str.print","msg":"${out}"}
{"op":"str.contains","s":"${out}","sub":"sandbox_test_ok","as":"ok"}
{"op":"str.print","msg":"DEBUG: out='${out}' ok='${ok}'"}
{"op":"flow.if","cond":"'${ok}' == 'True'"}
{"op":"str.print","msg":"Sandbox Execute Success"}
{"op":"flow.else"}
{"op":"str.print","msg":"Sandbox Execute Failed"}
{"op":"flow.endif"}
