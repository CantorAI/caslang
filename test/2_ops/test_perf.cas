{"op":"flow.set","name":"root","value":"D:/CantorAI/caslang"}
{"op":"fs.list","dir":"${root}","pattern":"*.h","recursive":true,"as":"files"}
{"op":"flow.set","name":"count","value":0}
{"op":"flow.loop_start","var":"file","in":"${files}"}
  {"op":"fs.stat","path":"${file}","as":"st"}
  {"op":"str.print","msg":"${file} size: ${st}"}
  {"op":"flow.if","cond":"${st} != null"}
     {"op":"flow.set","name":"count","value":"=${count} + 1"}
  {"op":"flow.endif"}
{"op":"flow.loop_end"}
{"op":"flow.return","value":"${count}"}
