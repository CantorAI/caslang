{"op":"flow.set","name":"dir","value":"d:/CantorAI/caslang/test"}
{"op":"fs.list","dir":"${dir}","pattern":"*","recursive":true,"as":"list"}
{"op":"flow.set","name":"file_count","value":0}
{"op":"flow.set","name":"folder_count","value":0}
{"op":"flow.loop_start","var":"item","in":"${list}"}
  {"op":"str.contains","s":"${item}","sub":".","as":"has_ext"}
  {"op":"flow.if","cond":"'${has_ext}' == 'True'"}
    {"op":"flow.set","name":"file_count","value":"=${file_count} + 1"}
  {"op":"flow.else"}
    {"op":"flow.set","name":"folder_count","value":"=${folder_count} + 1"}
  {"op":"flow.endif"}
{"op":"flow.loop_end"}
{"op":"flow.return","value":"{\"files\":${file_count},\"folders\":${folder_count}}"}
